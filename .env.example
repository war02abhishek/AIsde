# OpenAI
OPENAI_API_KEY=sk-...

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=aisde_docs

# Express Server
PORT=3000
NODE_ENV=development

# ── MCP Configuration ─────────────────────────────────────────────
#
# MCP_SERVER_URL controls which transport multi-client uses:
#
#   LOCAL DEV (leave empty):
#     MCP runs in-process via InMemoryTransport
#     No extra container needed, zero network overhead
#
#   PRODUCTION / Model B (set to MCP service URL):
#     MCP runs as separate HTTP service via StreamableHTTPClientTransport
#     Express calls MCP over HTTP: http://mcp-service:4000
#     In docker-compose: http://mcp:4000
#     In AWS ECS:        http://mcp-service.internal:4000
#
MCP_SERVER_URL=

# HTTP_TRANSPORT controls src/mcp/server.ts transport mode:
#   false = stdio (local dev, Cursor/Claude Desktop)
#   true  = HTTP  (production, listens on MCP_PORT)
HTTP_TRANSPORT=false
MCP_PORT=4000

# ── External MCP Servers ──────────────────────────────────────────
# GitHub MCP server (optional)
# Get token from: https://github.com/settings/tokens
# Scopes needed: repo, read:org
GITHUB_TOKEN=

# Proxy (corporate — leave empty if not behind proxy)
HTTPS_PROXY=
HTTP_PROXY=
NODE_TLS_REJECT_UNAUTHORIZED=
